# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# OpenRouter (AI)
OPENROUTER_API_KEY=

# CloudPayments
NEXT_PUBLIC_CP_PUBLIC_ID=
CP_API_SECRET=

# Tochka ID OAuth (2026-07) — общий OAuth-клиент с go.mpstats.
# Реальные значения (client_id/secret) прописываются только в рантайм-env
# (.env / docker-compose), НЕ в git. Флаг off = кнопка и роуты инертны.
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
TOCHKA_REDIRECT_URI=https://platform.mpstats.academy/api/auth/tochka/callback
TOCHKA_LOGIN_ENABLED=false
# TOCHKA_SSO_BASE_URL=  # default https://id.tochka.com/api/v1/tochka-id/auth/v1/sso
# TOCHKA_SCOPE=         # default openid,customers

# Sentry Monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Staging-only flags (only set in .env.staging, leave empty/unset in .env.production)
# NEXT_PUBLIC_STAGING=true       # Shows yellow STAGING banner, hides Yandex Metrika

# ---------------------------------------------------------------------------
# RAG REST API (Stage 5 — consumed by Ai_MP_manager and other internal agents)
# ---------------------------------------------------------------------------
# JSON array of opaque bearer tokens accepted by POST /api/rag/search.
# Issue one token per consumer (e.g. aim-agent, mcp-wrapper) so you can
# rotate them independently. Tokens are matched constant-time; never log them.
# Example: RAG_API_TOKENS=["aim_local_dev_xxx", "aim_prod_yyy"]
RAG_API_TOKENS=[]
